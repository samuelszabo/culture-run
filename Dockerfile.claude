FROM node:22-slim

# Browsers install to a shared, world-readable path; scripts resolve the global
# `playwright` module via NODE_PATH. Pin the version to the cached browser build.
ENV PLAYWRIGHT_BROWSERS_PATH=/ms-playwright \
    NODE_PATH=/usr/local/lib/node_modules \
    PLAYWRIGHT_VERSION=1.60.0

# git/ssh for the workflow + headless-Chromium runtime libs so Claude can
# screenshot the running game for visual debugging (Playwright).
RUN apt-get update && apt-get install -y --no-install-recommends \
      git openssh-client ca-certificates \
      libglib2.0-0 libnspr4 libnss3 libdbus-1-3 libatk1.0-0 libatk-bridge2.0-0 \
      libcups2 libdrm2 libxcb1 libxkbcommon0 libatspi2.0-0 libx11-6 libxext6 \
      libxcomposite1 libxdamage1 libxfixes3 libxrandr2 libgbm1 \
      libpango-1.0-0 libcairo2 libasound2 fonts-liberation \
  && npm install -g @anthropic-ai/claude-code "playwright@${PLAYWRIGHT_VERSION}" \
  && npx --yes "playwright@${PLAYWRIGHT_VERSION}" install chromium \
  && chmod -R a+rX /ms-playwright \
  && rm -rf /var/lib/apt/lists/* /root/.npm

RUN mkdir -p /home/node/.claude && chown node:node /home/node/.claude
ENV CLAUDE_CONFIG_DIR=/home/node/.claude
USER node
WORKDIR /workspace
